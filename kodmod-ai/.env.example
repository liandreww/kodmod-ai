# KODMOD AI — Example environment file.
# Copy to `.env` and fill in real values for your deployment.

# ----------- runtime
ENV=dev
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# ----------- API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*
JWT_SECRET=change-me-to-a-32+-byte-secret
JWT_ALG=HS256
JWT_EXPIRE_MIN=1440

# ----------- database (PostgreSQL with pgvector)
DB_USER=kodmod
DB_PASSWORD=kodmod
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kodmod

# ----------- redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ----------- llm
KODMOD_LLM_PROVIDER=anthropic     # anthropic | openai | ollama | vllm
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# VLLM_BASE_URL=http://localhost:8001/v1

LLM_ROUTER_MODEL=claude-haiku-4-5-20251001
LLM_TUTOR_MODEL=claude-opus-4-7
LLM_QUIZ_MODEL=claude-sonnet-4-6
LLM_SCORING_MODEL=claude-sonnet-4-6
LLM_RECOMMENDATION_MODEL=claude-sonnet-4-6
LLM_REFLECTION_MODEL=claude-haiku-4-5-20251001

# ----------- rag
EMBEDDING_PROVIDER=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
VECTOR_BACKEND=pgvector            # pgvector | qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_TOP_K=8
RAG_RERANK_TOP_K=4

# ----------- voice
STT_BACKEND=faster-whisper         # faster-whisper | openai-whisper | deepgram
STT_MODEL=large-v3
STT_DEVICE=auto                    # cuda | cpu | auto
STT_COMPUTE_TYPE=float16
STT_LANGUAGE=id

TTS_BACKEND=piper                  # piper | azure | elevenlabs | coqui
TTS_VOICE=id-ID-ArdiNeural
TTS_RATE=1.0
# AZURE_TTS_KEY=
# AZURE_TTS_REGION=
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=

AUDIO_DIR=/var/lib/kodmod/audio
UPLOAD_DIR=/var/lib/kodmod/uploads
MAX_AUDIO_SECONDS=120

# ----------- observability
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=kodmod-ai
LANGCHAIN_TRACING_V2=false
PROMETHEUS_ENABLED=true

# ----------- pedagogy
DEFAULT_DIFFICULTY=medium
DEFAULT_LANGUAGE=id
QUIZ_PASS_THRESHOLD=0.6
MASTERY_PROMOTION=0.8
SOCRATIC_DEPTH=3

# ----------- accessibility
ACCESSIBILITY_DEFAULT_PROFILE=blind
SSML_ENABLED=true
MAX_SPOKEN_SENTENCE_WORDS=22
